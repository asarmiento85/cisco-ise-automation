# Secrets
.env
.env.*
!.env.example
ansible/vault/*.yml
!ansible/vault/.gitkeep
!ansible/vault/secrets.example.yml

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.egg-info/

# uv
uv.lock

# Ansible
*.retry
.ansible/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# Rendered switch configs (may contain secrets)
switch_configs/rendered/*
!switch_configs/rendered/.gitkeep

# VM / OVA artifacts
*.ova
*.iso
*.vmdk
*.vmx

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp

# Per-snapshot backup directories — keep local only. Even though the
# export script redacts known secret fields, snapshots capture lab-specific
# IDs, IPs, and operational state that doesn't belong in a shared repo.
# Remove these lines if you want every local backup tracked.
backups/*/
backups/latest
