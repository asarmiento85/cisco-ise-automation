# Copy to .env and fill in after the ISE VM is deployed.
# .env is gitignored — never commit real creds.

# --- ISE PAN (Primary Admin Node) ---
ISE_HOST=ise.lab.local
ISE_PORT=443
ISE_USERNAME=ersadmin
ISE_PASSWORD=changeme
ISE_VERIFY_SSL=false

# --- Switch defaults (Ansible will prefer vault/secrets.yml in real runs) ---
SWITCH_USERNAME=admin
SWITCH_PASSWORD=changeme
SWITCH_ENABLE=changeme

# --- RADIUS shared secret (between switches and ISE) ---
RADIUS_SHARED_SECRET=changeme-long-random-string
